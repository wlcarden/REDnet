# REDnet deployment config — copy to `rednet.env` and edit, then run ./setup.sh
# (secrets are generated separately into gitignored files; do NOT put secrets here)

# Your Matrix server_name. ★ IMMUTABLE after first deploy. Use a real domain in production.
REDNET_DOMAIN=rednet.test

# Front HTTP port for the single-host dev deploy. Production uses 443 + auto-TLS on a real domain.
REDNET_HTTP_PORT=8080

# Interface the single-host front binds to. Defaults to 127.0.0.1 (localhost only) so the
# governance/vouch data isn't exposed to the LAN. Set to 0.0.0.0 only to reach a dev box
# (e.g. a Raspberry Pi) from another device on a TRUSTED network.
# REDNET_BIND_IP=0.0.0.0

# ★ PRODUCTION (two-host): the real public HTTPS base clients reach. Becomes MAS's OIDC issuer +
# public_base, Synapse's public_baseurl, and the client well-known. MUST be https:// in production
# (OIDC issuer validity + the MAS cookie Secure flag). Leave blank for single-host dev (-> http://localhost).
# REDNET_PUBLIC_BASE=https://rednet.example

# Retention — the dial between organizing memory and seizure exposure (DESIGN/SPEC).
REDNET_RETENTION_DAYS=7
REDNET_MEDIA_RETENTION_DAYS=7

# Element Web branding + pinned upstream version for the soft-fork client (./element-web/build.sh).
REDNET_BRAND=REDnet
ELEMENT_VERSION=v1.11.86

# Group calls — an isolated post-v1 module (DESIGN §8). Requires a LiveKit SFU on a separate
# public-IP box in production (WebRTC needs direct UDP). Set to true and run bootstrap-calls.sh.
REDNET_CALLS_ENABLED=false

# Your Matrix user ID — used by governance tooling (mint-invite.sh, confirm-vouch.sh) as the
# default voucher identity. Every invite you mint is attributed to this identity.
# REDNET_OPERATOR=@yourname:rednet.example

# Auto-update — pulls latest code from the repo and rebuilds affected services.
# Controlled by ./update.sh (manual) or ./update.sh --auto (cron/systemd timer).
# touch .update-hold to immediately pause all updates (emergency kill switch).
# OFF by default: an unattended 15-min pull+rebuild of the CORE is remote code
# execution if the git remote is pushed to / MITM'd / subpoenaed (audit F3). Opt
# in only with signed commits + an allowed-signers file so verification can pass.
REDNET_AUTO_UPDATE=false
# REDNET_VERIFY_SIGNATURES=true   # require signed commits in auto mode (default: true)
# REDNET_UPDATE_REMOTE=origin
# REDNET_UPDATE_BRANCH=main

# Backups (backup.sh + the hourly timer) refuse to write a CLEARTEXT crown-jewel
# bundle unless an encrypted off-box target is set. For production, set both (repo
# key held OFF the core, ideally append-only object storage):
# RESTIC_REPOSITORY=s3:https://...
# RESTIC_PASSWORD=...
# To accept cleartext-at-rest instead (NOT for production), set:
# REDNET_ALLOW_CLEARTEXT_BACKUP=true

# Jurisdiction & hosting are a DEPLOY-TARGET choice (foreign-owned, non-Eyes — DESIGN §6b),
# not a value here. This file configures the software; you choose where it runs.
