{
  "name": "rednet-onboarding-module",
  "version": "0.1.0",
  "description": "REDnet Phase-1 silent onboarding/recovery as an Element CryptoSetupExtensions module (replaces the integration.patch soft fork, which was a non-applying template).",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/index.ts --bundle --format=cjs --platform=browser --target=es2021 --external:matrix-js-sdk --external:@matrix-org/react-sdk-module-api --outfile=lib/index.js",
    "test:shamir": "node test/shamir-behavioral.mjs",
    "test:escrow": "node test/escrow-behavioral.mjs",
    "test": "node test/shamir-behavioral.mjs && node test/escrow-behavioral.mjs"
  },
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@matrix-org/react-sdk-module-api": "2.4.0",
    "esbuild": "^0.28.1",
    "matrix-js-sdk": "34.12.0",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "shamir-secret-sharing": "^0.0.4"
  }
}
