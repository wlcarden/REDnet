# Relaxed yamllint for the REDnet deploy tree — we care about parse-correctness and real structural
# problems (the `: ` mapping trap, truthy ambiguity, duplicate keys), not cosmetic line-length/spacing.
extends: relaxed
rules:
  line-length: disable
  comments: disable
  comments-indentation: disable
  document-start: disable
  trailing-spaces: disable
  empty-lines: disable
  brackets: disable
  braces: disable
